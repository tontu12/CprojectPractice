{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "cppbuild",
            "label": "C/C++: cl.exe アクティブなファイルのビルド",
            "command": "cl.exe",
            "args": [
                "/Zi",
                "/FS",
                "/EHsc",
                "/nologo",
                "${file}",
                "/Fo${workspaceFolder}\\build\\",
                "/Fd${workspaceFolder}\\build\\${fileBasenameNoExtension}.pdb",
                "/Fe${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
                "/link",
                "/OUT:${workspaceFolder}\\build\\${fileBasenameNoExtension}.exe",
                "/PDB:${workspaceFolder}\\build\\${fileBasenameNoExtension}.pdb",
                "/ILK:${workspaceFolder}\\build\\${fileBasenameNoExtension}.ilk"
            ],
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": [
                "$msCompile"
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "detail": "アクティブな C/C++ ファイルを build フォルダへ出力します。"
        }
    ]
}